<UserControl x:Class="RadialActions.HelpSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RadialActions"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=local:HelpSettingsViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RadialActions;component/Settings/SettingsViewResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0"
              MinHeight="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportHeight}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0"
                          Grid.RowSpan="3"
                          Header="Getting Started"
                          Margin="0"
                          Style="{StaticResource SettingsCardGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Radial Actions"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="Build your own shortcut wheel for the apps and actions you use most.&#x0a;"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,0,0,8"
                                   Text="Use the Actions tab to add slices for apps, files, folders, scripts, and key commands.&#x0a;"
                                   TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource QuickStartStepTextBlock}">
                            <Run FontWeight="Bold">1.</Run>
                            Press
                            <Run Text="{Binding Settings.ActivationHotkey, Mode=OneWay}"
                                 FontWeight="Bold" />
                            to open the radial menu</TextBlock>
                        <TextBlock Style="{StaticResource QuickStartStepTextBlock}">
                            <Run FontWeight="Bold">2.</Run>
                            Use the mouse or the arrow keys to select a slice and click the mouse or hit Enter to run it</TextBlock>
                        <TextBlock Style="{StaticResource QuickStartStepTextBlock}">
                            <Run FontWeight="Bold">3.</Run>
                            Access more options with right click or Shift+F10</TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="4"
                          Header="Support"
                          Margin="0"
                          Style="{StaticResource SettingsCardGroupBox}">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8">
                            <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions">📦 View on GitHub</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,8">
                            <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions/issues">🐛 Report a Bug</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,8">
                            <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions/releases">🚀 Release Notes</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,8">
                            <Hyperlink NavigateUri="radialactions://licenses">📜 Third-Party Licenses</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <GroupBox Grid.Column="2"
                      Header="More from the Author"
                      Margin="0"
                      Style="{StaticResource SettingsCardGroupBox}">
                <StackPanel>
                    <UniformGrid Columns="2"
                                 Margin="0,4,0,0">
                        <StackPanel Style="{StaticResource ProjectTileStackPanel}">
                            <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                <Hyperlink NavigateUri="https://github.com/danielchalmers/JournalApp">Good Diary</Hyperlink>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ProjectDescriptionTextBlock}"
                                       Text="Track your daily activities and moods on Android." />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ProjectTileStackPanel}">
                            <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                <Hyperlink NavigateUri="https://github.com/danielchalmers/DesktopClock">DesktopClock</Hyperlink>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ProjectDescriptionTextBlock}"
                                       Text="A digital clock for your desktop." />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ProjectTileStackPanel}">
                            <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                <Hyperlink NavigateUri="https://github.com/danielchalmers/SentryReplay">Sentry Replay</Hyperlink>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ProjectDescriptionTextBlock}"
                                       Text="Review Tesla dashcam clips on Windows." />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ProjectTileStackPanel}">
                            <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                <Hyperlink NavigateUri="https://github.com/danielchalmers/SteamAccountSwitcher">SteamAccountSwitcher</Hyperlink>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ProjectDescriptionTextBlock}"
                                       Text="Swap Steam accounts from the system tray." />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ProjectTileStackPanel}">
                            <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                <Hyperlink NavigateUri="https://github.com/danielchalmers/Network-Monitor">Network Monitor</Hyperlink>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ProjectDescriptionTextBlock}"
                                       Text="Live latency and bandwidth in a desktop widget." />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ProjectTileStackPanel}">
                            <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                <Hyperlink NavigateUri="https://github.com/danielchalmers/Teichos">Teichos</Hyperlink>
                            </TextBlock>
                            <TextBlock Style="{StaticResource ProjectDescriptionTextBlock}"
                                       Text="Stay focused with URL blocking and schedules." />
                        </StackPanel>
                    </UniformGrid>
                    <TextBlock Margin="0,0,0,8">
                        <Hyperlink NavigateUri="https://github.com/danielchalmers">View all projects on GitHub</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
