<Window x:Class="RadialActions.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:RadialActions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Settings"
        Width="1200" Height="800"
        d:DataContext="{d:DesignInstance Type=local:SettingsWindowViewModel}"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RadialActions;component/Settings/SettingsViewResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Visibility="{Binding IsUpdateAvailable, Source={x:Static local:App.CurrentApp}, Converter={local:BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           VerticalAlignment="Center"
                           Text="&#xE896;" />
                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold"
                               FontSize="13"
                               TextWrapping="Wrap">
                        <Run Text="Update available: " />
                        <Run Text="{Binding LatestVersion, Source={x:Static local:App.CurrentApp}}" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0"
                               TextWrapping="Wrap">
                        A new version of Radial Actions is available!
                        <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions/releases/latest">Learn more</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="12,0,12,0"
                    Padding="0,12,0,0"
                    SelectedIndex="{Binding Settings.SettingsTabIndex, Mode=TwoWay}">
            <TabItem Header="_General">
                <local:GeneralSettingsView DataContext="{Binding General}" />
            </TabItem>

            <TabItem Header="_Actions">
                <local:ActionsSettingsView DataContext="{Binding Actions}" />
            </TabItem>

            <TabItem Header="Ad_vanced">
                <local:AdvancedSettingsView DataContext="{Binding Advanced}" />
            </TabItem>

            <TabItem Header="_Help">
                <local:HelpSettingsView DataContext="{Binding Help}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
